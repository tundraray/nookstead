# ============================================
# Colyseus Game Server Environment Variables
# ============================================

# REQUIRED: NextAuth JWT encryption secret
# Must be at least 32 characters
# Generate with: openssl rand -base64 32
# CRITICAL: Must match the AUTH_SECRET in the game app
AUTH_SECRET=sad

# REQUIRED: PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@host:port/database


# OPTIONAL: Colyseus server port (default: 2567)
COLYSEUS_PORT=2567

# OPTIONAL: CORS allowed origin (default: http://localhost:3000)
# Set to your game client URL in production
CORS_ORIGIN=http://localhost:3000

# ============================================
# Production vs Development
# ============================================

# DEVELOPMENT:
# - CORS_ORIGIN=http://localhost:3000
# - Cookie name: authjs.session-token

# PRODUCTION:
# - CORS_ORIGIN=https://your-game-client.com
# - Cookie name: __Secure-authjs.session-token (automatic over HTTPS)
# - NODE_ENV=production (detected automatically)

