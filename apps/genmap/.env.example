# =============================================================================
# S3-Compatible Object Storage (for apps/genmap sprite management)
# =============================================================================
# Supports AWS S3, Cloudflare R2, or MinIO (local development)
#
# CORS CONFIGURATION REQUIRED:
# Before sprite uploads work, configure CORS on your S3 bucket to allow
# PUT requests from your development URL (e.g., http://localhost:4200).
# See https://docs.aws.amazon.com/AmazonS3/latest/userguide/cors.html
# =============================================================================

# S3 endpoint URL
# AWS S3:        https://s3.{region}.amazonaws.com
# Cloudflare R2: https://{account-id}.r2.cloudflarestorage.com
# MinIO (local): http://localhost:9000
S3_ENDPOINT=http://localhost:9000

# S3 bucket name (must be created before running the app)
S3_BUCKET=nookstead-sprites

# S3 credentials
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# S3 region (required by AWS SDK even for MinIO)
# AWS S3:   us-east-1 (or your region)
# MinIO:    us-east-1 (any value works)
S3_REGION=us-east-1

# =============================================================================
# OpenAI API (for NPC character generation)
# =============================================================================
OPENAI_API_KEY=sk-your-key-here
