{
  "name": "@nookstead/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./adapters/next": {
      "types": "./src/adapters/next.ts",
      "import": "./src/adapters/next.ts",
      "default": "./src/adapters/next.ts"
    },
    "./adapters/colyseus": {
      "types": "./src/adapters/colyseus.ts",
      "import": "./src/adapters/colyseus.ts",
      "default": "./src/adapters/colyseus.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "import": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    }
  },
  "nx": {
    "name": "db",
    "tags": ["scope:core", "type:data"]
  },
  "dependencies": {
    "drizzle-orm": "^0.38.0",
    "postgres": "^3.4.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "dotenv": "^16.4.0"
  }
}
