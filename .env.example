# ============================================
# Quick Start
# ============================================

# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Generate AUTH_SECRET:
#    openssl rand -base64 32
#
# 3. Set up PostgreSQL database:
#    createdb nookstead
#
# 4. Configure OAuth providers:
#    - Google: https://console.cloud.google.com/apis/credentials
#    - Discord: https://discord.com/developers/applications
#
# 5. Copy .env to apps/server/.env:
#    cp .env apps/server/.env
#
# 6. Start services:
#    pnpm nx dev game      # Game client on :3000
#    pnpm nx serve server  # Game server on :2567

# ============================================
# Nookstead Project Environment Variables
# ============================================

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/nookstead

# NextAuth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-key-min-32-chars-here

# NextAuth Providers (OAuth)
# Get credentials from Google Cloud Console and Discord Developer Portal
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret
AUTH_DISCORD_ID=your-discord-client-id
AUTH_DISCORD_SECRET=your-discord-client-secret

# ============================================
# Colyseus Game Server
# ============================================

# Server port (used by server app)
COLYSEUS_PORT=2567

# CORS origin (used by server app)
CORS_ORIGIN=http://localhost:3000

# Client WebSocket URL (used by game app, injected via SSR)
COLYSEUS_URL=ws://localhost:2567

# ============================================
# Production vs Development
# ============================================

# DEVELOPMENT:
# - COLYSEUS_URL=ws://localhost:2567
# - CORS_ORIGIN=http://localhost:3000
# - OAuth redirect URIs: http://localhost:3000/api/auth/callback/google

# PRODUCTION:
# - COLYSEUS_URL=wss://your-game-server.com
# - CORS_ORIGIN=https://your-game-client.com
# - OAuth redirect URIs: https://your-game-client.com/api/auth/callback/google
# - Use __Secure-authjs.session-token cookie (automatic over HTTPS)
